# Copy to .env.local and fill in. Optional: the app runs without these;
# polls and suggestion submit stay disabled until both are set.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public URL (no trailing slash). If the app lives in a subpath on your domain,
# include it here — e.g. https://xiaoyanghu.com/design-resources — so Open Graph and basePath match.
# Omit on Vercel preview or local dev unless you need to test subpath routing locally.
# NEXT_PUBLIC_SITE_URL=https://xiaoyanghu.com/your-path
